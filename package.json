{
  "name": "demos_tailwind",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev",
    "stg": "cross-env NUXT_ENV_STAGE=staging&&nuxt dev",
    "start": "cross-env NUXT_ENV_STAGE=production&&nuxt start",
    "pre": "cross-env NUXT_ENV_STAGE=preproduction&&nuxt dev",
    "generate:dev": "cross-env NUXT_ENV_STAGE=development&&npm version patch --no-git-tag-version&&nuxt generate --devtools",
    "generate:dev--no-version": "cross-env NUXT_ENV_STAGE=development&&nuxt generate --devtools",
    "build:dev": "cross-env NUXT_ENV_STAGE=development&&npm version patch --no-git-tag-version&&nuxt build --devtools",
    "build:dev--no-version": "cross-env NUXT_ENV_STAGE=development&&nuxt build --devtools",
    "generate:pre": "cross-env NUXT_ENV_STAGE=preproduction&&npm version patch --no-git-tag-version&&nuxt generate --devtools",
    "generate:pre--no-version": "cross-env NUXT_ENV_STAGE=preproduction&&nuxt generate --devtools",
    "build:pre": "cross-env NUXT_ENV_STAGE=preproduction&&npm version patch --no-git-tag-version&&nuxt build --devtools",
    "build:pre--no-version": "cross-env NUXT_ENV_STAGE=preproduction&&nuxt build --devtools",
    "generate:pro": "cross-env NUXT_ENV_STAGE=production&&npm version patch --no-git-tag-version&&nuxt generate",
    "generate:pro--no-version": "cross-env NUXT_ENV_STAGE=production&&nuxt generate",
    "build:pro": "cross-env NUXT_ENV_STAGE=production&&npm version patch --no-git-tag-version&&nuxt build",
    "build:pro--no-version": "cross-env NUXT_ENV_STAGE=production&&nuxt build"
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@pinia/nuxt": "^0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@vesp/nuxt-fontawesome": "^2.0.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "chart.js": "^4.5.1",
    "daisyui": "^5.5.19",
    "docxtemplater": "^3.68.3",
    "nuxt": "^4.4.2",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^3.0.4",
    "pizzip": "^3.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@primevue/nuxt-module": "^4.5.4",
    "@types/node": "^25.5.2",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tailwindcss-primeui": "^0.6.1"
  }
}
